# === API (.env in api/) ===
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_JWT_SECRET=             # optional — only needed for legacy HS256 projects
STAGE=dev
APP_URL=http://localhost:3000
MCP_URL=http://localhost:8080/mcp
# Optional comma-separated extra web origins if you access the app via a custom domain
CORS_ALLOWED_ORIGINS=
# Used to encrypt per-KB provider secrets stored in the database
LLMWIKI_SETTINGS_ENCRYPTION_KEY=
# Shared secret used by the cron service when calling the internal compile endpoint
LLMWIKI_AUTOMATION_SECRET=
# Optional provider defaults used when a KB setting omits a model
ANTHROPIC_MODEL=
OPENROUTER_MODEL=
# Defaults for new per-KB automatic compile schedules
LLMWIKI_COMPILE_MAX_SOURCES=20
LLMWIKI_COMPILE_MAX_TOOL_ROUNDS=50
LLMWIKI_COMPILE_DEFAULT_MAX_TOKENS=50000
# Self-hosting default: keep OCR enabled, but disable commercial page-limit enforcement
OCR_PAGE_LIMITS_ENABLED=false
# Optional one-off local/manual run by slug
LLMWIKI_COMPILE_KB=

# Voyage AI (embeddings) — optional for v1
VOYAGE_API_KEY=
TURBOPUFFER_API_KEY=

# === Web (.env.local in web/) ===
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_MCP_URL=http://localhost:8080/mcp
